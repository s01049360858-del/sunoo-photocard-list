<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>선우 포카 리스트</title>

<style>
body {
  font-family: sans-serif;
  background: #f5f5f5;
  text-align: center;
}

h1 {
  margin-top: 20px;
}

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
  gap: 15px;
  padding: 20px;
}

.card {
  width: 120px;
  height: 170px;
  background: white;
  border-radius: 10px;
  overflow: hidden;
  cursor: pointer;
  transition: 0.3s;
}

.card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: grayscale(100%) brightness(70%);
  transition: 0.3s;
}

.card.collected img {
  filter: none;
}

.progress {
  margin: 15px;
  font-weight: bold;
}
</style>
</head>

<body>

<h1>💛 선우 포카 리스트 💛</h1>
<div class="progress" id="progress"></div>

<div class="grid" id="grid">
</div>

<script>
const photocards = [
  "https://picsum.photos/120/170?random=1",
  "https://picsum.photos/120/170?random=2",
  "https://picsum.photos/120/170?random=3",
  "https://picsum.photos/120/170?random=4",
  "https://picsum.photos/120/170?random=5",
  "https://picsum.photos/120/170?random=6"
];
];

const grid = document.getElementById("grid");

photocards.forEach((src, index) => {
  const card = document.createElement("div");
  card.className = "card";

  const img = document.createElement("img");
  img.src = src;

  card.appendChild(img);

  if(localStorage.getItem("card"+index) === "true"){
    card.classList.add("collected");
  }

  card.addEventListener("click", () => {
    card.classList.toggle("collected");
    localStorage.setItem("card"+index, card.classList.contains("collected"));
    updateProgress();
  });

  grid.appendChild(card);
});

function updateProgress(){
  const total = photocards.length;
  let collected = 0;
  photocards.forEach((_, i) => {
    if(localStorage.getItem("card"+i) === "true"){
      collected++;
    }
  });
  document.getElementById("progress").innerText =
    `수집률: ${collected} / ${total} (${Math.round(collected/total*100)}%)`;
}

updateProgress();
</script>

</body>
</html>
